<!-- Roles Section -->
<h3><%= l(:label_simplified_roles) %></h3>
<p>
  <em class="info"><%= l(:label_simplified_roles_hint) %></em>
</p>
<% Role.givable.sorted.each do |role| %>
  <p>
    <%= check_box_tag 'settings[simplified_roles][]', 
                      role.id, 
                      (@settings['simplified_roles'] || []).map(&:to_s).include?(role.id.to_s),
                      id: "settings_simplified_roles_#{role.id}" %>
    <%= label_tag "settings_simplified_roles_#{role.id}", role.name, style: "display:inline; float:none; margin-left:5px;" %>
  </p>
<% end %>
<%= hidden_field_tag 'settings[simplified_roles][]', '' %>

<!-- Groups Section -->
<h3><%= l(:label_simplified_groups) %></h3>
<p>
  <em class="info"><%= l(:label_simplified_groups_hint) %></em>
</p>
<% Group.sorted.each do |group| %>
  <p>
    <%= check_box_tag 'settings[simplified_groups][]', 
                      group.id, 
                      (@settings['simplified_groups'] || []).map(&:to_s).include?(group.id.to_s),
                      id: "settings_simplified_groups_#{group.id}" %>
    <%= label_tag "settings_simplified_groups_#{group.id}", group.lastname, style: "display:inline; float:none; margin-left:5px;" %>
  </p>
<% end %>
<%= hidden_field_tag 'settings[simplified_groups][]', '' %>

