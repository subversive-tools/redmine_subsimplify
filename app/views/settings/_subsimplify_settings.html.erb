<fieldset class="box"><legend><%= l(:label_simplified_roles) %></legend>
  <p style="color: #888; font-style: italic; margin-top: 0; margin-bottom: 10px;"><%= l(:label_simplified_roles_hint) %></p>
  <% Role.sorted.each do |role| %>
    <p>
      <label><%= role.name %></label>
      <%= check_box_tag 'settings[simplified_roles][]', role.id, (@settings['simplified_roles'] || []).include?(role.id.to_s) %>
    </p>
  <% end %>
  <%= hidden_field_tag 'settings[simplified_roles][]', '' %>
</fieldset>

<fieldset class="box"><legend><%= l(:label_simplified_groups) %></legend>
  <p style="color: #888; font-style: italic; margin-top: 0; margin-bottom: 10px;"><%= l(:label_simplified_groups_hint) %></p>
  <% Group.sorted.each do |group| %>
    <p>
      <label><%= group.name %></label>
      <%= check_box_tag 'settings[simplified_groups][]', group.id, (@settings['simplified_groups'] || []).include?(group.id.to_s) %>
    </p>
  <% end %>
  <%= hidden_field_tag 'settings[simplified_groups][]', '' %>
</fieldset>

<fieldset class="box"><legend><%= l(:label_ui_simplification) %></legend>
  <p style="color: #888; font-style: italic; margin-top: 0; margin-bottom: 10px;"><%= l(:label_ui_simplification_hint) %></p>
  <p style="margin-bottom: 5px;"><%= l(:label_to_hide) %></p>
  <p>
    <label><%= l(:label_hide_sidebar) %></label>
    <%= check_box_tag 'settings[hide_sidebar]', true, @settings['hide_sidebar'] %>
  </p>
  <p>
    <label><%= l(:label_hide_filters) %></label>
    <%= check_box_tag 'settings[hide_filters]', true, @settings['hide_filters'] %>
  </p>
  <p>
    <label><%= l(:label_hide_top_menu) %></label>
    <%= check_box_tag 'settings[hide_top_menu]', true, @settings['hide_top_menu'] %>
  </p>
  <p>
    <label><%= l(:label_hide_footer) %></label>
    <%= check_box_tag 'settings[hide_footer]', true, @settings['hide_footer'] %>
  </p>
  <p>
    <label><%= l(:label_hide_my_account) %></label>
    <%= check_box_tag 'settings[hide_my_account]', true, @settings['hide_my_account'] %>
  </p>
  <p>
    <label><%= l(:label_hide_user_profile_links) %></label>
    <%= check_box_tag 'settings[hide_user_profile_links]', true, @settings['hide_user_profile_links'], id: 'settings_hide_user_profile_links' %>
  </p>
  <p>
    <label><%= l(:label_hide_overview) %></label>
    <%= check_box_tag 'settings[hide_overview]', true, @settings['hide_overview'] %>
  </p>
</fieldset>

<fieldset class="box"><legend><%= l(:label_allowed_modules) %></legend>
  <p style="color: #888; font-style: italic; margin-top: 0; margin-bottom: 10px;"><%= l(:label_allowed_modules_hint) %></p>
  <p style="margin-bottom: 5px;"><%= l(:label_to_show) %></p>
  <% 
    # Get all available modules
    all_modules = Redmine::AccessControl.permissions.map(&:project_module).uniq.compact.map(&:to_s)
    all_modules << 'activity' unless all_modules.include?('activity')
    
    # Define standard order
    priority_order = [
      'activity',
      'issue_tracking', 
      'gantt', 
      'calendar', 
      'news', 
      'documents', 
      'wiki', 
      'boards', 
      'files', 
      'repository'
    ]
    
    # Sort: Priority ones first (in order), then others alphabetically
    sorted_modules = all_modules.sort_by do |mod| 
      idx = priority_order.index(mod)
      [idx ? 0 : 1, idx || mod]
    end

    sorted_modules.each do |mod| 
  %>
    <p>
      <label><%= l("label_module_#{mod}", default: mod.humanize) %></label>
      <%= check_box_tag 'settings[allowed_modules][]', mod, (@settings['allowed_modules'] || []).include?(mod) %>
    </p>
  <% end %>
  <%= hidden_field_tag 'settings[allowed_modules][]', '' %>
</fieldset>

<fieldset class="box" id="profile_privacy_settings"><legend><%= l(:label_user_profile_privacy) %></legend>
  <p style="color: #888; font-style: italic; margin-top: 0; margin-bottom: 10px;"><%= l(:label_user_profile_privacy_hint) %></p>
  <p style="margin-bottom: 5px;"><%= l(:label_to_hide) %></p>
  <p>
    <label><%= l(:label_hide_user_issues) %></label>
    <%= check_box_tag 'settings[hide_user_issues]', true, @settings['hide_user_issues'] %>
  </p>
  <p>
    <label><%= l(:label_hide_user_projects) %></label>
    <%= check_box_tag 'settings[hide_user_projects]', true, @settings['hide_user_projects'] %>
  </p>
  <p>
    <label><%= l(:label_hide_user_activity) %></label>
    <%= check_box_tag 'settings[hide_user_activity]', true, @settings['hide_user_activity'] %>
  </p>
  <p>
    <label><%= l(:label_hide_user_others) %></label>
    <%= check_box_tag 'settings[hide_user_others]', true, @settings['hide_user_others'] %>
  </p>
</fieldset>

<fieldset class="box"><legend><%= l(:label_custom_css_hiding) %></legend>
  <p style="color: #888; font-style: italic; margin-top: 0; margin-bottom: 10px;"><%= l(:label_custom_css_hiding_hint) %></p>
  <p>
    <%= text_area_tag 'settings[custom_hidden_selectors]', @settings['custom_hidden_selectors'], rows: 5, style: "width: 100%; box-sizing: border-box; font-family: monospace;" %>
  </p>
</fieldset>

<script type="text/javascript">
  $(document).ready(function() {
    var globalProfileCheck = $('#settings_hide_user_profile_links');
    var profilePrivacyBox = $('#profile_privacy_settings');

    function toggleProfilePrivacyBox() {
      if (globalProfileCheck.is(':checked')) {
        profilePrivacyBox.hide();
      } else {
        profilePrivacyBox.show();
      }
    }

    // Run on load
    toggleProfilePrivacyBox();

    // Run on change
    globalProfileCheck.change(toggleProfilePrivacyBox);
  });
</script>
